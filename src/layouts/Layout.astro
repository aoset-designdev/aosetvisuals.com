---
// src/layouts/Layout.astro
import '../styles/global.css';
import { locales, type Locale } from '../i18n/config';
import { localizePath, switchLocalePath } from '../i18n/utils';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  ogImage?: string;
}

const {
  title,
  description = 'AOSET — Elevating aesthetics across physical and digital environments.',
  locale,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://aoset.com');
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- PWA -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0a1128" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- hreflang alternates -->
    {locales.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(switchLocalePath(Astro.url, l), Astro.site ?? 'https://aoset.com')}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath('en', '/'), Astro.site ?? 'https://aoset.com')} />

    <!-- Google Fonts: Poppins (self-host in production for better perf) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme init — prevents FOUC, runs synchronously before paint -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('aoset-theme');
          const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          const theme = stored ?? preferred;
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-surface)] text-[var(--color-text)] antialiased">
    <Header locale={locale} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
