---
// src/components/ServicesOverview.astro
// NOTE: Add images to src/assets/services/ (kitchens.jpg, bathrooms.jpg, interiors.jpg)
import { useTranslations, localizePath } from '../i18n/utils';
import type { Locale } from '../i18n/config';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const bgColors = [
  'from-[var(--color-ramp-600)] to-[var(--color-ramp-800)]',
  'from-[var(--color-ramp-700)] to-[var(--color-ramp-900)]',
  'from-[var(--color-ramp-500)] to-[var(--color-ramp-700)]',
];
---

<section class="mx-auto max-w-7xl px-4 py-16 text-center sm:px-6 lg:px-8 lg:py-24">
  <h2 class="text-3xl font-semibold leading-snug text-[var(--color-text)] sm:text-4xl">
    {t.servicesOverview.heading}
  </h2>

  <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-3">
    {t.servicesOverview.items.map((service, index) => (
      <a
        href={localizePath(locale, service.href)}
        class={`group relative isolate flex aspect-[306/726] items-end justify-center overflow-hidden rounded-lg bg-gradient-to-b ${bgColors[index]} sm:aspect-[2/3] lg:aspect-[306/726]`}
      >
        <!--
          Replace the gradient div with:
          <Image src={images[index]} alt={service.title}
            class="absolute inset-0 -z-20 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            widths={[306, 612]} sizes="(min-width:640px) 33vw, 100vw" format="avif" quality={80} />
        -->
        <div class="absolute inset-0 -z-10 bg-black/30 transition-colors group-hover:bg-black/40" aria-hidden="true"></div>
        <span class="relative pb-8 text-xl font-semibold text-white sm:text-2xl">
          {service.title}
        </span>
      </a>
    ))}
  </div>

  <a
    href={localizePath(locale, '/services')}
    class="mt-12 inline-flex items-center justify-center rounded-md bg-[var(--color-accent)] px-8 py-3 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-accent-dark)]"
  >
    {t.servicesOverview.cta}
  </a>
</section>
